/************************************************
 * ROFI Color theme
 * Adaptado para: Main #141618 | Secondary #fafafa
 ***********************************************/

* {
    /* Cores Principais */
    background:                  rgba ( 20, 22, 24, 100 % ); /* #141618 */
    foreground:                  rgba ( 250, 250, 250, 100 % ); /* #fafafa */
    
    /* Variações de Seleção (Invertido para contraste) */
    selected-normal-background:  rgba ( 250, 250, 250, 100 % );
    selected-normal-foreground:  rgba ( 20, 22, 24, 100 % );
    
    /* Elementos de Interface */
    separatorcolor:              rgba ( 250, 250, 250, 20 % );
    border-color:                rgba ( 250, 250, 250, 100 % );
    
    /* Estados Alternados (Levemente mais claro que o fundo) */
    alternate-normal-background: rgba ( 30, 33, 36, 100 % );
    alternate-normal-foreground: @foreground;
    
    /* Alinhamento com o restante do sistema */
    normal-background:           @background;
    normal-foreground:           @foreground;
    spacing:                     2;
    background-color:            rgba ( 0, 0, 0, 0 % );
}

window {
    background-color: @background;
    border:           1;
    padding:          5; /* Aumentei um pouco para respirar melhor */
}

mainbox {
    border:  0;
    padding: 0;
}

message {
    border:       2px 0px 0px ;
    border-color: @separatorcolor;
    padding:      1px ;
}

textbox {
    text-color: @foreground;
}

listview {
    fixed-height: 0;
    border:       2px 0px 0px ;
    border-color: @separatorcolor;
    spacing:      1px ; /* Mais espaço entre os itens */
    scrollbar:    false; /* Desativado para um look mais clean */
    padding:      10px 0px 0px ;
}

element {
    border:  0;
    padding: 3px ; /* Preenchimento quadrado nos itens */
}

element-text {
    background-color: inherit;
    text-color:       inherit;
}

element.normal.normal {
    background-color: @normal-background;
    text-color:       @normal-foreground;
}

element.selected.normal {
    background-color: @selected-normal-background;
    text-color:       @selected-normal-foreground;
}

element.alternate.normal {
    background-color: @alternate-normal-background;
    text-color:       @alternate-normal-foreground;
}

/* 
 * Ajuste de Input 
 */
inputbar {
    spacing:    0;
    text-color: @normal-foreground;
    padding:    5px ;
    children:   [ prompt,textbox-prompt-colon,entry,case-indicator ];
}

prompt {
    spacing:    0;
    text-color: @normal-foreground;
}

textbox-prompt-colon {
    expand:     false;
    str:        " > "; /* Troquei o : por uma seta mais moderna */
    margin:     0px 0.3em 0em 0em ;
    text-color: @normal-foreground;
}

entry {
    spacing:    0;
    text-color: @normal-foreground;
}
